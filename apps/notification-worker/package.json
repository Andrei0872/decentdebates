{
  "name": "notification-worker",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rm -rf dist",
    "dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "test:integration": "corepack pnpm -C ../.. run docker:up && corepack pnpm -C ../.. run docker:wait && corepack pnpm run test:integration:only",
    "test:integration:only": "jest --config ./test/jest-integration.json --runInBand"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@decentdebates/db": "workspace:*",
    "@decentdebates/shared-types": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "bullmq": "^5.76.8",
    "ioredis": "^5.0.0",
    "pg": "^8.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@decentdebates/eslint-config": "workspace:*",
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.6.5",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
