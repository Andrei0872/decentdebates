{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rm -rf dist",
    "dev": "nest start --watch",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest",
    "test:integration": "corepack pnpm -C ../.. run docker:up && corepack pnpm -C ../.. run docker:wait && corepack pnpm run test:integration:only",
    "test:integration:only": "jest --config ./test/jest-integration.json --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "corepack pnpm -C ../.. run docker:up && corepack pnpm -C ../.. run docker:wait && corepack pnpm run test:e2e:only",
    "test:e2e:only": "jest --config ./test/jest-e2e.json --runInBand",
    "test:all": "corepack pnpm run test:unit && corepack pnpm -C ../.. run docker:up && corepack pnpm -C ../.. run docker:wait && corepack pnpm run test:integration:only && corepack pnpm run test:e2e:only"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@decentdebates/db": "workspace:*",
    "@decentdebates/shared-types": "workspace:*",
    "@lexical/link": "^0.9.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "express-session": "^1.18.0",
    "lexical": "^0.9.2",
    "pg": "^8.8.0",
    "redis": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.6.5",
    "@types/supertest": "^6.0.0",
    "@decentdebates/eslint-config": "workspace:*",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.20",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/",
      "/packages/db/dist/"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
