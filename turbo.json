{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": [
        "^lint:fix"
      ]
    },
    "start:prod": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    }
  }
}
