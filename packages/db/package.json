{
  "name": "@decentdebates/db",
  "version": "0.0.1",
  "private": true,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:clean": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "seed": "tsc -p tsconfig.json && knex --knexfile dist/knexfile.js seed:run",
    "seed:file": "tsc -p tsconfig.json && knex --knexfile dist/knexfile.js seed:run --specific"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.0.3",
    "pg": "^8.8.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^22.0.0",
    "knex": "^2.4.2",
    "typescript": "^5.7.0"
  }
}
